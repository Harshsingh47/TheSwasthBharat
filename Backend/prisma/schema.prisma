generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String?

  googleId  String?  @unique
  authProvider String @default("EMAIL")   // ✅ MUST exist
  isEmailVerified Boolean @default(false) // ✅ MUST exist
  avatarUrl String?                       // ✅ MUST exist

  role      Role
  createdAt DateTime @default(now())

  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?

  appointments   Appointment[]
}

model DoctorProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique

  // Basic Info
  specialty           String?
  experience          Int?
  location            String?
  bio                 String?
  consultationFee     Int?

  // Professional Details
  qualification       String?
  university          String?
  registrationNumber  String?
  hospitalAffiliation String?

  // Verification
  degreeCertificateUrl String?
  idProofUrl           String?
  isVerified           Boolean @default(false)

  // Reputation
  rating              Float    @default(0)
  totalReviews        Int      @default(0)

  // Extra
  languagesSpoken     String?
  consultationMode    String? // ONLINE / OFFLINE / BOTH

  user User @relation(fields: [userId], references: [id])
  appointments Appointment[]   // ✅ ADD THIS
  availabilities DoctorAvailability[]   // ✅ ADD THIS
}

model PatientProfile {
  id        String   @id @default(uuid())
  userId    String   @unique

  // Basic Info
  age        Int?
  gender     String?
  bloodGroup String?
  location   String?

  // Medical Info
  allergies          String?
  existingConditions String?

  // Emergency
  emergencyContactName  String?
  emergencyContactPhone String?

  // Social
  volunteerInterest Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
}

model Appointment {
  id        String   @id @default(uuid())
  patientId String
  doctorId  String

  date      DateTime
  status    AppointmentStatus @default(PENDING)
  reason    String?

  createdAt DateTime @default(now())

  patient User @relation(fields: [patientId], references: [id])
  doctor  DoctorProfile @relation(fields: [doctorId], references: [id])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model DoctorAvailability {
  id         String @id @default(uuid())
  doctorId   String

  dayOfWeek  Int     // 0 = Sunday, 1 = Monday...
  startTime  String  // "09:00"
  endTime    String  // "17:00"
  slotDuration Int   // in minutes

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])
}